<devicedata>
  <name>Sensor Multiplexer</name>
  <version/>
  <manufacturer>Finite Labs</manufacturer>
  <model>Sensor Multiplexer</model>
  <creator>Derek Miller</creator>
  <small image_source="c4z">icons/device_sm.png</small>
  <large image_source="c4z">icons/device_lg.png</large>
  <control>lua_gen</control>
  <driver>DriverWorks</driver>
  <copyright>Copyright 2026 Finite Labs, LLC. All rights reserved.</copyright>
  <created>02/06/2026 12:00:00 PM</created>
  <modified/>
  <combo>true</combo>
  <minimum_os_version>3.3.0</minimum_os_version>
  <composer_categories>
    <category>Sensors</category>
  </composer_categories>
  <conditionals/>
  <events/>
  <config>
    <script file="driver.lua" jit="1"/>
    <documentation file="www/documentation/index.html"/>
    <properties>
      <property>
        <name>Cloud Settings</name>
        <type>LABEL</type>
        <default>Cloud Settings</default>
      </property>
      <!-- #ifdef DRIVERCENTRAL -->
      <property>
        <name>Cloud Status</name>
        <default/>
        <type>STRING</type>
        <readonly>true</readonly>
      </property>
      <!-- #endif -->
      <property>
        <name>Automatic Updates</name>
        <type>LIST</type>
        <items>
          <item>Off</item>
          <item>On</item>
        </items>
        <default>On</default>
      </property>
      <!-- #ifndef DRIVERCENTRAL -->
      <property>
        <name>Update Channel</name>
        <type>LIST</type>
        <default>Production</default>
        <items>
          <item>Production</item>
          <item>Prerelease</item>
        </items>
      </property>
      <!-- #endif -->
      <property>
        <name>Driver Settings</name>
        <type>LABEL</type>
        <default>Driver Settings</default>
      </property>
      <property>
        <name>Driver Status</name>
        <type>STRING</type>
        <default/>
        <readonly>true</readonly>
      </property>
      <property>
        <name>Driver Version</name>
        <type>STRING</type>
        <default/>
        <readonly>true</readonly>
      </property>
      <property>
        <name>Log Level</name>
        <type>LIST</type>
        <default>3 - Info</default>
        <items>
          <item>0 - Fatal</item>
          <item>1 - Error</item>
          <item>2 - Warning</item>
          <item>3 - Info</item>
          <item>4 - Debug</item>
          <item>5 - Trace</item>
          <item>6 - Ultra</item>
        </items>
      </property>
      <property>
        <name>Log Mode</name>
        <type>LIST</type>
        <default>Off</default>
        <items>
          <item>Off</item>
          <item>Print</item>
          <item>Log</item>
          <item>Print and Log</item>
        </items>
      </property>
      <!-- Input Configuration -->
      <property>
        <name>Input Configuration</name>
        <type>LABEL</type>
        <default>Input Configuration</default>
      </property>
      <property>
        <name>Input Names</name>
        <type>STRING</type>
        <default/>
        <description>Comma-delimited list of input names (e.g., Home, Away, Vacation)</description>
      </property>
      <property>
        <name>Enable Temperature</name>
        <type>LIST</type>
        <default>Yes</default>
        <items>
          <item>Yes</item>
          <item>No</item>
        </items>
      </property>
      <property>
        <name>Enable Humidity</name>
        <type>LIST</type>
        <default>Yes</default>
        <items>
          <item>Yes</item>
          <item>No</item>
        </items>
      </property>
      <property>
        <name>Enable Contact</name>
        <type>LIST</type>
        <default>No</default>
        <items>
          <item>Yes</item>
          <item>No</item>
        </items>
      </property>
      <!-- Multiplexer Output -->
      <property>
        <name>Multiplexer Output</name>
        <type>LABEL</type>
        <default>Multiplexer Output</default>
      </property>
      <property>
        <name>Active Input Name</name>
        <type>STRING</type>
        <default/>
        <readonly>true</readonly>
      </property>
      <property>
        <name>Output Temperature C</name>
        <type>STRING</type>
        <default/>
        <readonly>true</readonly>
      </property>
      <property>
        <name>Output Temperature F</name>
        <type>STRING</type>
        <default/>
        <readonly>true</readonly>
      </property>
      <property>
        <name>Output Humidity</name>
        <type>STRING</type>
        <default/>
        <readonly>true</readonly>
      </property>
      <property>
        <name>Output Contact</name>
        <type>STRING</type>
        <default/>
        <readonly>true</readonly>
      </property>
    </properties>
    <actions>
      <!-- #ifndef DRIVERCENTRAL -->
      <action>
        <name>Update Drivers</name>
        <command>Update_Drivers</command>
      </action>
      <!-- #endif -->
      <action>
        <name>Cycle Input</name>
        <command>Cycle_Input</command>
        <params/>
      </action>
      <action>
        <name>Reset Driver</name>
        <command>Reset_Driver</command>
        <params>
          <param>
            <name>Are You Sure?</name>
            <type>LIST</type>
            <items>
              <item>No</item>
              <item>Yes</item>
            </items>
          </param>
        </params>
      </action>
    </actions>
    <commands>
      <command>
        <name>Select Input</name>
        <description>Set NAME active input to PARAM1</description>
        <params>
          <param>
            <name>Input</name>
            <type>DYNAMIC_LIST</type>
          </param>
        </params>
      </command>
    </commands>
  </config>
  <capabilities/>
  <connections/>
</devicedata>
