<devicedata>
  <name>Variable Manipulator</name>
  <version/>
  <manufacturer>Finite Labs</manufacturer>
  <model>Variable Manipulator</model>
  <creator>Derek Miller</creator>
  <small image_source="c4z">icons/device_sm.png</small>
  <large image_source="c4z">icons/device_lg.png</large>
  <control>lua_gen</control>
  <driver>DriverWorks</driver>
  <copyright>Copyright 2026 Finite Labs, LLC. All rights reserved.</copyright>
  <created>07/10/2026 12:00:00 PM</created>
  <modified/>
  <combo>true</combo>
  <minimum_os_version>3.3.0</minimum_os_version>
  <composer_categories>
    <category>Other</category>
  </composer_categories>
  <conditionals/>
  <events>
    <event>
      <id>1</id>
      <name>String Created</name>
      <description>Fires each time the Create String command completes.</description>
    </event>
    <event>
      <id>2</id>
      <name>Equation Calculated</name>
      <description>Fires each time the Calculate Equation command completes successfully.</description>
    </event>
  </events>
  <config>
    <script file="driver.lua" jit="1"/>
    <documentation file="www/documentation/index.html"/>
    <properties>
      <property>
        <name>Cloud Settings</name>
        <type>LABEL</type>
        <default>Cloud Settings</default>
      </property>
      <!-- #ifdef DRIVERCENTRAL -->
      <property>
        <name>Cloud Status</name>
        <default/>
        <type>STRING</type>
        <readonly>true</readonly>
      </property>
      <!-- #endif -->
      <property>
        <name>Automatic Updates</name>
        <type>LIST</type>
        <items>
          <item>Off</item>
          <item>On</item>
        </items>
        <default>On</default>
      </property>
      <!-- #ifndef DRIVERCENTRAL -->
      <property>
        <name>Update Channel</name>
        <type>LIST</type>
        <default>Production</default>
        <items>
          <item>Production</item>
          <item>Prerelease</item>
        </items>
      </property>
      <!-- #endif -->
      <property>
        <name>Driver Settings</name>
        <type>LABEL</type>
        <default>Driver Settings</default>
      </property>
      <property>
        <name>Driver Status</name>
        <type>STRING</type>
        <default/>
        <readonly>true</readonly>
      </property>
      <property>
        <name>Driver Version</name>
        <type>STRING</type>
        <default/>
        <readonly>true</readonly>
      </property>
      <property>
        <name>Log Level</name>
        <type>LIST</type>
        <default>3 - Info</default>
        <items>
          <item>0 - Fatal</item>
          <item>1 - Error</item>
          <item>2 - Warning</item>
          <item>3 - Info</item>
          <item>4 - Debug</item>
          <item>5 - Trace</item>
          <item>6 - Ultra</item>
        </items>
      </property>
      <property>
        <name>Log Mode</name>
        <type>LIST</type>
        <default>Off</default>
        <items>
          <item>Off</item>
          <item>Print</item>
          <item>Log</item>
          <item>Print and Log</item>
        </items>
      </property>
      <!-- Output -->
      <property>
        <name>Output</name>
        <type>LABEL</type>
        <default>Output</default>
      </property>
      <property>
        <name>String Output</name>
        <type>STRING</type>
        <default/>
        <readonly>true</readonly>
        <description>The most recent result of the Create String command. Also published to the STRING variable.</description>
      </property>
      <property>
        <name>String Expression</name>
        <type>STRING</type>
        <default/>
        <readonly>true</readonly>
        <description>The most recent Create String template with each PARAM{} token rendered as [Room &gt; Device &gt; Variable].</description>
      </property>
      <property>
        <name>Equation Output</name>
        <type>STRING</type>
        <default/>
        <readonly>true</readonly>
        <description>The most recent result of the Calculate Equation command. Also published to the NUMBER variable.</description>
      </property>
      <property>
        <name>Equation Expression</name>
        <type>STRING</type>
        <default/>
        <readonly>true</readonly>
        <description>The most recent Calculate Equation template with each PARAM{} token rendered as [Room &gt; Device &gt; Variable].</description>
      </property>
      <!-- Token Builder -->
      <property>
        <name>Token Builder</name>
        <type>LABEL</type>
        <default>Token Builder</default>
      </property>
      <property>
        <name>Reference Variable</name>
        <type>VARIABLE_SELECTOR</type>
        <default/>
        <description>Select any variable in the project to build its PARAM{} token below.</description>
      </property>
      <property>
        <name>Reference Token</name>
        <type>STRING</type>
        <default/>
        <description>The PARAM{} token for the variable selected above. Select the text to copy it into a Create String or Calculate Equation command. Editing here has no effect; it is rewritten on the next selection.</description>
      </property>
    </properties>
    <actions>
      <!-- #ifndef DRIVERCENTRAL -->
      <action>
        <name>Update Drivers</name>
        <command>Update_Drivers</command>
      </action>
      <!-- #endif -->
      <action>
        <name>Reset Driver</name>
        <command>Reset_Driver</command>
        <params>
          <param>
            <name>Are You Sure?</name>
            <type>LIST</type>
            <items>
              <item>No</item>
              <item>Yes</item>
            </items>
          </param>
        </params>
      </action>
    </actions>
    <commands>
      <command>
        <name>Create String</name>
        <description>Create string PARAM1</description>
        <params>
          <param>
            <name>String</name>
            <type>STRING</type>
          </param>
        </params>
      </command>
      <command>
        <name>Calculate Equation</name>
        <description>Calculate equation PARAM1</description>
        <params>
          <param>
            <name>Equation</name>
            <type>STRING</type>
          </param>
        </params>
      </command>
    </commands>
  </config>
  <capabilities/>
  <connections/>
</devicedata>
